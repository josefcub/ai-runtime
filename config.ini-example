# Agent Harness Configuration
#

[server]
# Webhook listener
host = 127.0.0.1                               # Default 127.0.0.1
port = 8080                                    # Default 8080
webhook_path = "/webhook"                      # Default "/webhook"
max_body_bytes = 1048576                       # Max request body size in bytes, default is 1048576 (1MB)

[llm]
# OpenAI-compatible API (llama-server, etc.)
endpoint = "http://localhost:11434/v1"         # FATAL if empty (e.g. http://localhost:8080/v1)
model = "qwen-3.6-27b-planning"                # FATAL if empty (e.g. llama-3.1-8b)
api_key = ""                                   # default is ""
context_tokens = 131072                        # maximum context size in tokens, default is 8192  
summarize_threshold = 0.70                    # fraction of context window at which summarization triggers, default is 0.70
summarize_keep_recent = 10                    # number of most recent messages to keep unchanged, default is 10
max_tokens = 32768                             # maximum number of tokens generated per call, default is 4096
max_tool_iterations = 20                       # maximum tool-call loop iterations per message, default is 20
timeout = 900                                  # timeout in seconds per LLM call, default is 120
system_prompt = "You are a helpful agentic testing assistant."

[queue]
max_depth = 64             # Per-channel queue depth, default is 64

[paths]
working_dir = ./work/      # Tool sandbox root — all file ops are relative here
log_dir = ./logs/          # Log output directory (outside working_dir)
state_dir = ./state/       # Flat JSON session persistence
channel_log_dir =          # Per-channel JSONL conversation logs (empty = disabled)

[logging]
level = debug              # debug, info, warn, error
log_tool_calls = true
log_agent_reasoning = true
log_channel_events = true

[tools.bash]
enabled = true             # Enable the bash tool (default: true)
timeout = 60               # Default command timeout in seconds (default: 60)
max_output = 30720         # Max combined stdout+stderr bytes before truncation (default: 30720)
banned = "curl,wget,ssh,scp,ssh-keygen,nc,telnet,sudo,su,doas,rm,dd,chmod,chown,apt,apt-get,apt-cache,yum,dnf,brew,pip,pip3,npm,yarn,npx,pkg,pkg_add,apk,aptitude,makepkg,paru,pacman,zypper,rpm,emerge,service,systemctl,systemd,firewall-ctd,iptables,ufw,netstat,ifconfig,ip,route,crontab,at,batch,chkconfig,fdisk,mkfs,mount,umount,parted,scp,rsync"  # Comma-separated list of banned command names (case-insensitive)

